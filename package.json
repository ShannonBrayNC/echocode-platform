{
  "name": "echocodex-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Internal Codex-style engineering agent platform for the Lantern Protocol stack.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --import tsx tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "echocodex:run": "tsx src/cli/echocodex.ts --mode dryRun --json --mock"
  },
  "dependencies": {
    "@octokit/rest": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
