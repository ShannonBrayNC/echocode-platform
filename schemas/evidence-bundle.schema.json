{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidenceBundle",
  "type": "object",
  "required": [
    "evidence_id",
    "work_item_id",
    "summary",
    "artifacts",
    "status"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^EVD-[A-Z0-9]{6,}$"
    },
    "work_item_id": {
      "type": "string",
      "pattern": "^WI-[A-Z0-9]{6,}$"
    },
    "summary": {
      "type": "string",
      "minLength": 5
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "status": {
      "type": "string",
      "enum": ["draft", "complete"]
    }
  },
  "additionalProperties": false
}