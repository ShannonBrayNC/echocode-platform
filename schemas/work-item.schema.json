{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkItem",
  "type": "object",
  "required": [
    "work_item_id",
    "title",
    "requirement_ids",
    "expected_outcomes",
    "status"
  ],
  "properties": {
    "work_item_id": {
      "type": "string",
      "pattern": "^WI-[A-Z0-9]{6,}$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "requirement_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^REQ-[A-Z0-9]{6,}$"
      }
    },
    "design_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "expected_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "allowed_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "status": {
      "type": "string",
      "enum": ["planned", "in_progress", "review", "done", "blocked"]
    }
  },
  "additionalProperties": false
}